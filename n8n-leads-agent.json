    {
      "parameters": {
        "method": "GET",
        "url": "https://serpapi.com/search",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "engine", "value": "google" },
            { "name": "q", "value": "site:linkedin.com/in CEO OR CTO \"business automation\" -job -jobs" },
            { "name": "api_key", "value": "YOUR_SERPAPI_KEY" },
            { "name": "num", "value": "10" }
          ]
        },
        "options": { "response": { "response": { "neverError": true } } }
