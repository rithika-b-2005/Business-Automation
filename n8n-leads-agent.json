    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst content = raw.text ?? raw.content ?? raw.response ?? JSON.stringify(raw);\nlet scored;\ntry {\n  const cleaned = content.replace(/^```json\\s*/i, '').replace(/```\\s*$/i, '').trim();\n  scored = JSON.parse(cleaned);\n} catch (e) {\n  scored = { ...raw, score: 10, notes: 'AI scoring failed — manual review needed' };\n}\nscored.score = Math.min(100, Math.max(0, parseInt(scored.score ?? 10)));\nscored.processedAt = new Date().toISOString();\nreturn [{ json: scored }];"
      },
