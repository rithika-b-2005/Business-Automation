      "id": "node-serpapi-search",
      "name": "SerpAPI — Google Lead Search",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [540, 380]
    },
    {
      "parameters": {
        "jsCode": "const apolloData = $input.first().json;\nconst people = apolloData.people ?? [];\nconst leads = people.map(p => ({\n  name: `${p.first_name ?? ''} ${p.last_name ?? ''}`.trim(),\n  email: p.email ?? null,\n  phone: p.phone_numbers?.[0]?.sanitized_number ?? null,\n  company: p.organization?.name ?? null,\n  linkedinUrl: p.linkedin_url ?? null,\n  title: p.title ?? null,\n  source: 'apollo',\n  rawScore: 0\n})).filter(l => l.name && (l.email || l.linkedinUrl));\nreturn leads.map(l => ({ json: l }));"
      },
      "id": "node-normalize-apollo",
      "name": "Code — Normalize Apollo Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [780, 200]
    },
    {
      "parameters": {
        "jsCode": "const serpData = $input.first().json;\nconst results = serpData.organic_results ?? [];\nconst leads = results.map(r => {\n  const titleMatch = r.title?.match(/^([^\\-|]+)/);\n  const name = titleMatch ? titleMatch[1].trim() : 'Unknown';\n  const companyMatch = r.snippet?.match(/at ([A-Z][^,\\.]+)/);\n  const company = companyMatch ? companyMatch[1].trim() : null;\n  const linkedinUrl = r.link?.includes('linkedin.com') ? r.link : null;\n  return { name, email: null, phone: null, company, linkedinUrl, title: null, source: 'serpapi', rawScore: 0, snippet: r.snippet ?? null };\n}).filter(l => l.name !== 'Unknown' && l.linkedinUrl);\nreturn leads.map(l => ({ json: l }));"
      },
      "id": "node-normalize-serp",
      "name": "Code — Normalize SerpAPI Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [780, 380]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body ?? $input.first().json;\nconst lead = {\n  name: `${body.firstName ?? ''} ${body.lastName ?? ''}`.trim() || body.name || 'Unknown',\n  email: body.email ?? null,\n  phone: body.phone ?? null,\n  company: body.company ?? null,\n  linkedinUrl: body.linkedin ?? body.linkedinUrl ?? null,\n  title: body.title ?? null,\n  source: 'website_form',\n  rawScore: 0,\n  message: body.message ?? null\n};\nreturn [{ json: lead }];"
      },
      "id": "node-normalize-webhook",
      "name": "Code — Normalize Webhook Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [540, 500]
    },
    {
      "parameters": {
        "jsCode": "const msg = $input.first().json;\nconst fromHeader = msg.payload?.headers?.find(h => h.name === 'From')?.value ?? msg.from ?? '';\nconst subjectHeader = msg.payload?.headers?.find(h => h.name === 'Subject')?.value ?? '';\nconst emailMatch = fromHeader.match(/([^<>]+)?\\s*<([^>]+)>|([\\w._%+\\-]+@[\\w.\\-]+\\.[A-Z]{2,})/i);\nconst name = emailMatch?.[1]?.trim() ?? fromHeader.split('@')[0] ?? 'Unknown';\nconst email = emailMatch?.[2] ?? emailMatch?.[3] ?? null;\nconst lead = { name, email, phone: null, company: null, linkedinUrl: null, title: null, source: 'gmail_reply', rawScore: 0, snippet: msg.snippet ?? '', originalSubject: subjectHeader };\nreturn [{ json: lead }];"
      },
      "id": "node-normalize-gmail",
      "name": "Code — Normalize Gmail Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [540, 900]
