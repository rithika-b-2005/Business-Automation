          "messageValues": [
            {
              "message": "=You are a B2B lead scoring AI for Tec Tha (business automation SaaS). Analyze this lead and return ONLY a JSON object with: name (string), email (string|null), phone (string|null), company (string|null), linkedinUrl (string|null), title (string|null), source (keep as-is), score (0-100 integer: +30 verified email, +15 phone, +10 linkedin, +10 company, +20 C-level title, +15 warm source, +10 apollo source, -20 no email and no linkedin), notes (1-2 sentence insight). Input: {{ JSON.stringify($json) }}"
            }
          ]
