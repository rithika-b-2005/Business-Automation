generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?  @unique
  phone     String?  @unique
  company   String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RegistrationOtp {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  firstName String
  lastName  String
  company   String?
  password  String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("registration_otps")
}

model Job {
  id           String           @id @default(cuid())
  title        String
  type         String
  location     String
  duration     String
  description  String
  skills       String[]
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  applications JobApplication[]

  @@map("jobs")
}

model JobApplication {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id])
  firstName     String
  lastName      String
  email         String
  phone         String?
  city          String?
  country       String?
  linkedin      String?
  experience    String?
  qualification String?
  availability  String?
  company       String?
  whyJoin       String?
  coverLetter   String?
  portfolio     String?
  resumeText    String?
  matchScore    Int?
  createdAt     DateTime @default(now())

  @@map("job_applications")
}

model DemoBooking {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  company         String?
  companySize     String?
  message         String?
  date            String
  timeSlot        String
  scheduledAt     DateTime?
  meetLink        String?
  reminder24hSent Boolean   @default(false)
  reminder1hSent  Boolean   @default(false)
  status          String    @default("pending")
  createdAt       DateTime  @default(now())

  @@map("demo_bookings")
}

model PasswordResetOtp {
  id         String   @id @default(cuid())
  email      String?  @unique
  phone      String?  @unique
  otp        String
  resetToken String?  @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@map("password_reset_otps")
}

model Lead {
  id          String    @id @default(cuid())
  name        String
  email       String?   @unique
  phone       String?
  company     String?
  linkedinUrl String?
  title       String?
  source      String
  score       Int       @default(0)
  notes       String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("leads")
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
