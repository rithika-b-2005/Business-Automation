generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  email          String?        @unique
  phone          String?        @unique
  company        String?
  password       String
  role           String         @default("USER")
  platformAccess String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  refreshTokens  RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model RegistrationOtp {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  firstName String
  lastName  String
  company   String?
  password  String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("registration_otps")
}

model Job {
  id           String           @id @default(cuid())
  title        String
  type         String
  location     String
  duration     String
  description  String
  skills       String[]
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  applications JobApplication[]

  @@map("jobs")
}

model JobApplication {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id])
  firstName     String
  lastName      String
  email         String
  phone         String?
  city          String?
  country       String?
  linkedin      String?
  experience    String?
  qualification String?
  availability  String?
  company       String?
  whyJoin       String?
  coverLetter   String?
  portfolio     String?
  resumeText    String?
  matchScore    Int?
  createdAt     DateTime @default(now())

  @@map("job_applications")
}

model DemoBooking {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  company         String?
  companySize     String?
  message         String?
  date            String
  timeSlot        String
  scheduledAt     DateTime?
  meetLink        String?
  reminder24hSent Boolean   @default(false)
  reminder1hSent  Boolean   @default(false)
  status          String    @default("pending")
  createdAt       DateTime  @default(now())

  @@map("demo_bookings")
}

model PasswordResetOtp {
  id         String   @id @default(cuid())
  email      String?  @unique
  phone      String?  @unique
  otp        String
  resetToken String?  @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@map("password_reset_otps")
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Lead {
  id                    String    @id @default(cuid())
  name                  String
  email                 String?   @unique
  phone                 String?
  company               String?
  website               String?
  title                 String?
  location              String?
  industry              String?
  source                String    @default("form_generated")
  linkedinUrl           String?
  score                 Int?      @default(0)
  icpLabel              String?
  companyBio            String?
  automationOpportunity String?
  leadContext           String?
  outreachLine          String?
  emailSubject          String?
  emailBody             String?
  outreachStatus        String    @default("new")
  notes                 String?
  processedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("leads")
}

model MarketingLead {
  id             String    @id @default(cuid())
  name           String
  email          String?
  phone          String?
  company        String?
  website        String?
  location       String?
  industry       String?
  source         String    @default("serper_maps")
  score          Int?      @default(0)
  icpLabel       String?
  companyBio     String?
  campaignIdea   String?
  contentAngle   String?
  adCopy         String?
  emailSubject   String?
  emailBody      String?
  outreachStatus String    @default("new")
  notes          String?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("marketing_leads")
}

model SalesLead {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  website         String?
  location        String?
  industry        String?
  source          String    @default("serper_maps")
  score           Int?      @default(0)
  icpLabel        String?
  companyBio      String?
  painPoint       String?
  salesPitch      String?
  proposalSummary String?
  emailSubject    String?
  emailBody       String?
  outreachStatus  String    @default("new")
  notes           String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("sales_leads")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  feedback  String
  rating    Int
  createdAt DateTime @default(now())

  @@map("testimonials")
}

model Question {
  id        String   @id @default(cuid())
  name      String
  email     String
  question  String
  answered  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("questions")
}
